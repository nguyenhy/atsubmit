---
import Layout from "./BaseLayout.astro";
---

<Layout>
  <div class="section-padding container-wide max-w-4xl mx-auto mt-26 mb-10">
    <article class="markdown-body prose dark:prose-invert max-w-none">
      <slot />
    </article>
  </div>
</Layout>

<style lang="scss" is:global>
  @import "../styles/tailwind.css";

  @layer components {
    article.markdown-body {
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        margin: 0 0 0.5rem 0;
        color: rgb(var(--black));
        line-height: 1.2;
      }

      h1 {
        @apply text-5xl md:text-6xl lg:text-7xl;
      }

      h2 {
        @apply text-4xl md:text-5xl lg:text-6xl;
      }

      h3 {
        @apply text-3xl md:text-4xl lg:text-5xl;
      }

      h4 {
        @apply text-2xl md:text-3xl lg:text-4xl;
      }

      h5 {
        @apply text-xl md:text-2xl lg:text-3xl;
      }

      [id^="slug_"] > a {
        @apply mr-2;
      }

      strong,
      b {
        font-weight: 700;
      }

      a {
        color: var(--accent);
      }

      a:hover {
        color: var(--accent);
      }

      p {
        margin-bottom: 1rem;
      }

      .prose {
        p {
          margin-bottom: 2rem;
        }

        > .expressive-code {
          @apply mb-2;
        }

        astro-playground {
          @apply mb-2;
        }
      }

      textarea {
        width: 100%;
        font-size: 16px;
      }

      input {
        font-size: 16px;
      }

      table {
        width: 100%;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
      }

      code {
        padding: 2px 5px;
        background-color: rgb(var(--gray-light));
        border-radius: 2px;
      }

      pre {
        padding: 1.5rem;
        border-radius: 8px;
      }

      pre > code {
        all: unset;
      }

      blockquote {
        border-left: 4px solid var(--accent);
        padding: 0 0 0 20px;
        margin: 0;

        @apply text-lg md:text-xl lg:text-2xl;
      }

      .sr-only {
        position: absolute !important;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: 0;
        overflow: hidden;
        white-space: nowrap;
        clip: rect(1px, 1px, 1px, 1px);
        clip-path: inset(50%);
        border: 0;
      }

      ul {
        @apply list-disc ml-4 pl-4;
      }

      hr {
        @apply h-px text-inherit my-8;
        border-top-width: 1px;
      }
    }
  }
</style>
