---
const productLinks = [
  { name: "Features", href: "/features" },
  { name: "Pricing", href: "/pricing" },
  { name: "Documentation", href: "/docs" },
  { name: "Changelog", href: "/changelog" },
];

const companyLinks = [
  { name: "About Us", href: "/about" },
  { name: "Contact", href: "/contact" },
  { name: "Blog", href: "/blog" },
];

const legalLinks = [
  { name: "Terms of Service", href: "/legal/en/terms" },
  { name: "Privacy Policy", href: "/legal/en/privacy" },
  { name: "Refund Policy", href: "/legal/en/refund" },
];
---

<footer class="bg-muted/50 border-t border-border pt-20 pb-10">
  <div
    class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-12 mb-16"
  >
    <!-- Brand -->
    <div class="col-span-2 lg:col-span-2">
      <a
        href="/"
        class="text-xl font-bold tracking-tight flex items-center gap-2 mb-6"
      >
        <div
          class="w-8 h-8 bg-apple-blue rounded-lg flex items-center justify-center text-white"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 2L2 22"></path>
            <path d="M2 2l20 20"></path>
          </svg>
        </div>
        <span>AtSubmit</span>
      </a>

      <p class="text-muted-foreground max-w-xs mb-6">
        The modern form backend for developers. Connect your HTML forms to our
        API and receive unlimited submissions.
      </p>
    </div>

    <!-- Product -->
    <div>
      <h4 class="font-bold mb-6">Product</h4>

      <ul class="space-y-4 text-sm text-muted-foreground">
        {
          productLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-foreground">
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h4 class="font-bold mb-6">Company</h4>

      <ul class="space-y-4 text-sm text-muted-foreground">
        {
          companyLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-foreground">
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Legal -->
    <div>
      <h4 class="font-bold mb-6">
        <a href="/legal/references">Legal</a>
      </h4>

      <ul class="space-y-4 text-sm text-muted-foreground">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-foreground">
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Bottom -->
  <div
    class="max-w-7xl mx-auto px-6 pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-muted-foreground"
  >
    <p>© 2026 AtSubmit. All rights reserved.</p>

    <div class="flex gap-6">
      <a href="#" class="hover:text-foreground">Twitter</a>
      <a href="#" class="hover:text-foreground">GitHub</a>
      <a href="#" class="hover:text-foreground">LinkedIn</a>
    </div>
  </div>
</footer>
