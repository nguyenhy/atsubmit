---
import {
  CircleCheck,
  ArrowRight,
  CodeXml,
  ShieldCheck,
  Zap,
  ChartColumn,
  BellRing,
  Globe,
} from "@lucide/astro";

const steps = [
  {
    step: "01",
    title: "Connect your form",
    desc: "Point your form action to our unique API endpoint.",
  },
  {
    step: "02",
    title: "Receive submissions",
    desc: "We handle basic validation, spam protection, and storage.",
  },
  {
    step: "03",
    title: "Get notified",
    desc: "Receive instant alerts via Email, Slack, or Webhooks.",
  },
];

const devFeatures = [
  "AJAX / Fetch support",
  "Simple POST endpoint",
  "Works with any HTML form",
  "Spam honeypot included",
  "Basic validation",
];

const features = [
  {
    icon: Zap,
    title: "Unlimited Submissions",
    desc: "We never cap your growth. Receive as many submissions as you need.",
  },
  {
    icon: ShieldCheck,
    title: "Spam protection",
    desc: "Built-in protection to keep unwanted submissions out.",
  },
  {
    icon: BellRing,
    title: "Instant Notifications",
    desc: "Get notified via Email, Slack, Discord, or custom Webhooks.",
  },
  {
    icon: ChartColumn,
    title: "Analytics Dashboard",
    desc: "Visualize submission trends and conversion rates at a glance.",
  },
  {
    icon: Globe,
    title: "Works Everywhere",
    desc: "Perfect for Astro, Next.js, Hugo, WordPress, or plain HTML.",
  },
  {
    icon: CodeXml,
    title: "Developer API",
    desc: "Simple submission API endpoint.",
  },
];

const plans = [
  {
    name: "Free",
    price: "0",
    features: [
      "3 Forms",
      "Unlimited Submissions",
      "Weekly Digest",
      "CSV Export",
      "Basic Spam Filter",
    ],
  },
  {
    name: "Starter",
    price: "5",
    popular: true,
    features: [
      "20 Forms",
      "Daily Notifications",
      "Email Notifications",
      "Webhook Support",
      "Basic Analytics",
    ],
  },
  {
    name: "Pro",
    price: "19",
    features: [
      "100 Forms",
      "Instant Notifications",
      "Advanced Spam Filter",
      "Slack/Discord Alerts",
      "API Access",
    ],
  },
  {
    name: "Agency",
    price: "49",
    features: [
      "500 Forms",
      "Multi-client Workspace",
      "Team Access",
      "Priority Processing",
      "Advanced Analytics",
    ],
  },
];

const useCases = [
  {
    title: "Contact Forms",
    desc: "The classic use case. Get messages from your visitors directly in your inbox.",
  },
  {
    title: "Lead Generation",
    desc: "Capture potential customers and sync them with your CRM via webhooks.",
  },
  {
    title: "Newsletter Signup",
    desc: "Build your audience without setting up a complex backend.",
  },
  {
    title: "Customer Support",
    desc: "Create custom support forms that route to your team instantly.",
  },
];

const faqs = [
  {
    q: "How does integration work?",
    a: "Just set your form action to our API endpoint. We handle the rest. No backend code required.",
  },
  {
    q: "Is there a limit on submissions?",
    a: "We don’t enforce submission limits in the current version.",
  },
  {
    q: "Can I use it with React or Next.js?",
    a: "Absolutely. You can use standard forms or handle submissions via AJAX/Fetch.",
  },
  {
    q: "What is your refund policy?",
    a: "We offer a 14-day no-questions-asked refund policy for all paid plans.",
  },
];
---

<div class="pt-16">
  <!-- Hero -->
  <section
    class="flex flex-col items-center text-center container-wide"
  >
    <span
      class="px-4 py-1.5 rounded-full bg-apple-blue/10 text-apple-blue text-sm font-semibold mb-6 inline-block"
    >
      Unlimited submissions for everyone
    </span>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 max-w-4xl">
      Forms that just work.<br />
      <span class="text-apple-blue">No backend required.</span>
    </h1>

    <p class="text-xl text-muted-foreground mb-10 max-w-2xl mx-auto">
      Connect your HTML forms to our API and start receiving submissions in
      seconds. The simplest way to handle contact forms, lead gen, and more.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/signup"
        class="btn-primary text-lg px-8 flex items-center gap-2"
      >
        Start for Free <ArrowRight size={20} />
      </a>

      <a href="/docs" class="btn-secondary text-lg px-8">
        View Documentation
      </a>
    </div>

    <!-- Trust -->
    <div class="mt-24 w-full">
      <p
        class="text-sm font-medium text-muted-foreground uppercase tracking-widest mb-8"
      >
        Built for developers
        <div
          class="flex flex-wrap justify-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500"
        >
          <div class="font-bold text-2xl">Vercel</div>
          <div class="font-bold text-2xl">Netlify</div>
          <div class="font-bold text-2xl">Astro</div>
          <div class="font-bold text-2xl">Next.js</div>
          <div class="font-bold text-2xl">Stripe</div>
        </div>
      </p>
    </div>

    <!-- How it works -->
    <section class="section-padding bg-muted/50">
      <div class="container-wide">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Integration in 3 simple steps
          </h2>
          <p class="text-muted-foreground">
            Go from zero to production in less than 2 minutes.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-12">
          {
            steps.map((item) => (
              <div class="relative p-8 rounded-apple-lg bg-card border border-border shadow-sm">
                <span class="text-5xl font-bold text-apple-blue/20 absolute top-4 right-8">
                  {item.step}
                </span>

                <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                <p class="text-muted-foreground">{item.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Developer section -->
    <section class="section-padding container-wide">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Built for developers
          </h2>

          <p class="text-lg text-muted-foreground mb-8">
            No libraries to install. No complex SDKs. Just a standard HTML form.
            Works with any framework or static site generator.
          </p>

          <ul class="space-y-4">
            {
              devFeatures.map((f) => (
                <li class="flex items-center gap-3 font-medium">
                  <CircleCheck class="text-apple-blue" size={20} />
                  {f}
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="rounded-apple-lg overflow-hidden border border-border bg-[#0d1117] p-6 shadow-2xl"
        >
          <div
            class="flex items-center gap-2 mb-4 border-b border-white/10 pb-4"
          >
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-xs text-white/40 ml-2 font-mono">
              contact-form.html
            </span>
          </div>

          <pre
            class="text-sm font-mono text-white overflow-x-auto"><code>{`<form 
  action="https://api.atsubmit.com/f/your-id" 
  method="POST"
>
  <label>Email Address</label>
  <input type="email" name="email" required />

  <label>Message</label>
  <textarea name="message"></textarea>

  <button type="submit">Send</button>
</form>`}</code></pre>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="section-padding bg-muted/30">
      <div class="container-wide">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Everything you need to manage forms
          </h2>
          <p class="text-muted-foreground">
            Powerful features hidden behind a simple API.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            features.map((f) => {
              const Icon = f.icon;
              return (
                <div class="p-8 rounded-apple-lg bg-card border border-border hover:border-apple-blue/50 transition-colors">
                  <div class="w-12 h-12 rounded-lg bg-apple-blue/10 text-apple-blue flex items-center justify-center mb-6">
                    <Icon />
                  </div>

                  <h3 class="text-xl font-bold mb-3">{f.title}</h3>
                  <p class="text-muted-foreground">{f.desc}</p>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="section-padding container-wide">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Simple, transparent pricing
        </h2>

        <p class="text-muted-foreground">
          Pay only for the notifications you need. Submissions are always
          unlimited.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          plans.map((plan) => (
            <div
              class={`p-8 rounded-apple-lg border flex flex-col ${
                plan.popular
                  ? "border-apple-blue bg-apple-blue/5 ring-1 ring-apple-blue"
                  : "border-border bg-card"
              }`}
            >
              {plan.popular && (
                <span class="text-xs font-bold text-apple-blue uppercase tracking-widest mb-4">
                  Most Popular
                </span>
              )}

              <h3 class="text-xl font-bold mb-2">{plan.name}</h3>

              <div class="mb-6">
                <span class="text-4xl font-bold">${plan.price}</span>
                <span class="text-muted-foreground">/mo</span>
              </div>

              <ul class="space-y-4 mb-8 flex-grow">
                {plan.features.map((f) => (
                  <li class="flex items-center gap-2 text-sm">
                    <CircleCheck size={16} class="text-apple-blue" />
                    {f}
                  </li>
                ))}
              </ul>

              <button
                class={`w-full py-3 rounded-full font-bold transition-all ${
                  plan.popular
                    ? "bg-apple-blue text-white hover:opacity-90"
                    : "bg-muted text-foreground hover:bg-border"
                }`}
              >
                {plan.price === "0" ? "Get Started" : "Start Free Trial"}
              </button>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Use cases -->
    <section class="section-padding container-wide">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Built for every use case
        </h2>

        <p class="text-muted-foreground">
          From simple contact forms to complex lead generation workflows.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          useCases.map((u) => (
            <div class="text-center">
              <div class="w-16 h-16 rounded-full bg-apple-blue/5 flex items-center justify-center mx-auto mb-6">
                <CircleCheck class="text-apple-blue" size={24} />
              </div>

              <h3 class="text-lg font-bold mb-2">{u.title}</h3>
              <p class="text-sm text-muted-foreground">{u.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding bg-muted/30">
      <div class="container-wide max-w-3xl">
        <h2 class="text-3xl font-bold mb-12 text-center">
          Frequently Asked Questions
        </h2>

        <div class="space-y-8">
          {
            faqs.map((faq) => (
              <div class="border-b border-border pb-6">
                <h3 class="text-lg font-bold mb-2">{faq.q}</h3>
                <p class="text-muted-foreground">{faq.a}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding container-wide text-center">
      <div class="bg-apple-blue rounded-apple-lg p-12 md:p-20 text-white">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Ready to simplify your forms?
        </h2>

        <p class="text-xl opacity-90 mb-10 max-w-2xl mx-auto">
          Start handling your forms the simple way. Start for free today.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/signup"
            class="px-8 py-4 bg-white text-apple-blue rounded-full font-bold text-lg hover:bg-opacity-90 transition-all"
          >
            Create Free Account
          </a>

          <a
            href="/pricing"
            class="px-8 py-4 bg-apple-blue border border-white/30 rounded-full font-bold text-lg hover:bg-white/10 transition-all"
          >
            View All Plans
          </a>
        </div>
      </div>
    </section>
  </section>
</div>
